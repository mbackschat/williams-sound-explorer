.DS_Store

# Generated by build:worklet (esbuild) — checked-in source is src/audio/worklet.ts
public/williams-sound-explorer-worklet.js
public/williams-sound-explorer-worklet.js.map

# ROMs are user-supplied (uploaded → IndexedDB); `npm run dev:roms` copies the
# locally-built bins here for one-click dev.  Never committed.
public/roms/*.bin

# NOTE: public/data/*.json (glossary, labelmap, zeropage, explainer) ARE
# committed — they're derived metadata (command codes, symbol addresses, cell
# names/descriptions) with no ROM bytes, and the public CI build can't
# regenerate labelmap/zeropage without the private source.  build_*.py skip
# gracefully when their inputs are absent and leave the committed JSON intact.
